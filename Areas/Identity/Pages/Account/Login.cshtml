@page
@model LoginModel

@{
    ViewData["Title"] = "Đăng nhập";
}

<div class="auth-page">
    <div class="auth-card">
        <div class="auth-left">
            <p class="eyebrow">Welcome Back</p>
            <h1>Đăng nhập CoffeeShop</h1>
            <p>
                Đăng nhập để thêm món vào giỏ hàng, thanh toán đơn hàng và theo dõi tài khoản của bạn.
            </p>

            <div class="admin-demo-box">
                <strong>Tài khoản admin test</strong>
                <span>Email: admin@coffeeshop.com</span>
                <span>Password: Admin@123</span>
            </div>
        </div>

        <div class="auth-right">
            <h2>Đăng nhập</h2>
            <p class="text-muted mb-4">Sử dụng tài khoản local để đăng nhập.</p>

            <form id="account" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label asp-for="Input.Email" class="form-label">Email</label>
                    <input asp-for="Input.Email" class="form-control modern-input" autocomplete="username" placeholder="name@example.com" />
                    <span asp-validation-for="Input.Email" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Input.Password" class="form-label">Mật khẩu</label>
                    <input asp-for="Input.Password" class="form-control modern-input" autocomplete="current-password" placeholder="password" />
                    <span asp-validation-for="Input.Password" class="text-danger"></span>
                </div>

                <div class="form-check mb-4">
                    <input class="form-check-input" asp-for="Input.RememberMe" />
                    <label asp-for="Input.RememberMe" class="form-check-label">
                        Ghi nhớ đăng nhập
                    </label>
                </div>

                <button id="login-submit" type="submit" class="btn btn-primary w-100 rounded-pill py-3">
                    Đăng nhập
                </button>

                <div class="auth-links mt-4">
                    <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl">
                        Tạo tài khoản mới
                    </a>

                    <a id="forgot-password" asp-page="./ForgotPassword">
                        Quên mật khẩu?
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}