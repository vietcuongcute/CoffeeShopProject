@{
    ViewData["Title"] = "Đặt hàng thành công";
}

<div class="modern-card text-center py-5">
    <p class="eyebrow">Order Success</p>

    <h1>Đặt hàng thành công!</h1>

    <p class="text-muted fs-5">
